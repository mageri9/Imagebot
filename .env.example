BOT_TOKEN=your_telegram_bot_token

# OpenAI-compatible aggregator
PROVIDER_BASE_URL=https://api.proxyapi.ru/openai/v1
PROVIDER_API_KEY=your_aggregator_key

# Default model (can be changed via admin command)
DEFAULT_IMAGE_MODEL=gpt-image-1

# Image generation defaults
IMAGE_SIZE=1024x1024
IMAGE_QUALITY=medium        # low | medium | high

# Quota
DEFAULT_DAILY_LIMIT=10

# Admin telegram user_id
ADMIN_IDS=[123456789]

# Logging
LOG_LEVEL=INFO
