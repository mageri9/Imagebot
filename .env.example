BOT_TOKEN=your_telegram_bot_token
ADMIN_IDS=[123456789]

# Provider type: openai_compat | genapi
PROVIDER_TYPE=openai_compat

# OpenAI-compatible aggregator (ProxyAPI, OpenRouter, etc.)
PROVIDER_BASE_URL=https://api.aitunnel.ru/v1
PROVIDER_API_KEY=your_aggregator_key

# Gen-API native provider (used when PROVIDER_TYPE=genapi)
GENAPI_BASE_URL=https://api.gen-api.ru
GENAPI_API_KEY=your_genapi_key

# Default model (overridable via /setmodel)
DEFAULT_IMAGE_MODEL=gpt-image-2

# Image defaults (overridable via /setquality, stored in DB)
IMAGE_SIZE=1024x1024
IMAGE_QUALITY=low

# Max photos in multi-image mode
MAX_MULTI_IMAGES=3

# Quota
DEFAULT_DAILY_LIMIT=1

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Logging
LOG_LEVEL=INFO
